# Team collaboration — per-member JSON files use union merge to prevent
# conflicts when two members join or update concurrently.
.workflow/collab/members/*.json merge=union

# Activity log is append-only; union merge preserves lines from both sides.
.workflow/collab/activity.jsonl merge=union

# Generated docs and cross-platform mirrors are byte-compared in release gates.
# Keep their text stable in Windows fresh checkouts.
*.md text eol=lf
*.toml text eol=lf
