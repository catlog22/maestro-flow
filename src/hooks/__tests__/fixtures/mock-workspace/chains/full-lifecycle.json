{
  "id": "full-lifecycle",
  "name": "Full Lifecycle",
  "entry": "plan",
  "nodes": {
    "plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "args": "{phase}",
      "next": "execute"
    },
    "execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "args": "{phase}",
      "next": "review"
    },
    "review": {
      "type": "command",
      "cmd": "quality-review",
      "args": "{phase}",
      "next": "check_review"
    },
    "check_review": {
      "type": "decision",
      "edges": [
        { "value": "BLOCK", "target": "fix_plan" },
        { "default": true, "target": "test" }
      ]
    },
    "fix_plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "args": "{phase} --gaps",
      "next": "fix_execute"
    },
    "fix_execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "args": "{phase}",
      "next": "review"
    },
    "test": {
      "type": "command",
      "cmd": "quality-test",
      "args": "{phase}",
      "next": "milestone_audit"
    },
    "milestone_audit": {
      "type": "command",
      "cmd": "maestro-milestone-audit",
      "next": "milestone_complete"
    },
    "milestone_complete": {
      "type": "command",
      "cmd": "maestro-milestone-complete",
      "next": "done"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
