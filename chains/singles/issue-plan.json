{
  "$schema": "../chain-graph.schema.json",
  "id": "singles/issue-plan",
  "name": "Issue Plan",
  "description": "Solution planning for a specific issue with codebase-aware step generation",
  "version": "1.0.0",
  "tags": [
    "manage",
    "issue"
  ],
  "entry": "issue_plan",
  "inputs": {
    "description": {
      "type": "string"
    }
  },
  "nodes": {
    "issue_plan": {
      "type": "command",
      "cmd": "manage-issue-plan",
      "next": "done",
      "analyze": false,
      "args": "\"{description}\"",
      "description": "Solution planning for a specific issue with codebase-aware step generation"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
