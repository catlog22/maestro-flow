{
  "$schema": "../chain-graph.schema.json",
  "id": "singles/issue-analyze",
  "name": "Issue Analyze",
  "description": "Root cause analysis for a specific issue using CLI exploration",
  "version": "1.0.0",
  "tags": [
    "manage",
    "issue"
  ],
  "entry": "issue_analyze",
  "inputs": {
    "description": {
      "type": "string"
    }
  },
  "nodes": {
    "issue_analyze": {
      "type": "command",
      "cmd": "manage-issue-analyze",
      "next": "done",
      "analyze": false,
      "args": "\"{description}\"",
      "description": "Root cause analysis for a specific issue using CLI exploration"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
