{
  "$schema": "../chain-graph.schema.json",
  "id": "singles/phase-add",
  "name": "Phase Add",
  "description": "Add or insert a new phase into the project roadmap with automatic renumbering",
  "version": "1.0.0",
  "tags": [
    "maestro",
    "phase"
  ],
  "entry": "phase_add",
  "inputs": {
    "description": {
      "type": "string"
    }
  },
  "nodes": {
    "phase_add": {
      "type": "command",
      "cmd": "maestro-phase-add",
      "next": "done",
      "analyze": false,
      "args": "\"{description}\"",
      "description": "Add or insert a new phase into the project roadmap with automatic renumbering"
    },
    "done": {
      "type": "terminal",
      "status": "success"
    }
  }
}
