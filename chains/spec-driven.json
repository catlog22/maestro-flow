{
  "$schema": "./chain-graph.schema.json",
  "id": "spec-driven",
  "name": "Spec-Driven",
  "description": "Init -> Spec Generate -> Plan -> Execute pipeline",
  "version": "1.0.0",
  "tags": ["lifecycle", "spec"],
  "entry": "init",
  "inputs": {
    "phase": { "type": "string" },
    "description": { "type": "string", "required": true }
  },
  "defaults": { "analyze": true },
  "nodes": {
    "init": {
      "type": "command",
      "cmd": "maestro-init",
      "description": "Initialize project structure and state files",
      "next": "spec_generate"
    },
    "spec_generate": {
      "type": "command",
      "cmd": "maestro-roadmap",
      "description": "Generate specification package through 7-phase document chain",
      "args": "--mode full \"{description}\"",
      "auto_flag": "-y",
      "next": "plan"
    },
    "plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "description": "Create execution plan with task decomposition",
      "args": "{phase}",
      "auto_flag": "--auto",
      "next": "execute"
    },
    "execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "description": "Run wave-based parallel task execution",
      "args": "{phase}",
      "next": "done"
    },
    "done": {
      "type": "terminal",
      "status": "success",
      "summary": "Spec-driven pipeline completed successfully"
    }
  }
}
