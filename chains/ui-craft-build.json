{
  "$schema": "./chain-graph.schema.json",
  "id": "ui-craft-build",
  "name": "UI Craft Build",
  "description": "UI Craft Build -> Plan -> Execute pipeline",
  "version": "1.0.0",
  "tags": ["lifecycle", "ui-design"],
  "entry": "ui_design",
  "inputs": {
    "phase": { "type": "string", "required": true }
  },
  "defaults": { "analyze": true },
  "nodes": {
    "ui_design": {
      "type": "command",
      "cmd": "maestro-impeccable",
      "description": "UI design-driven production via maestro-impeccable build chain",
      "args": "\"{phase}\" --chain build",
      "auto_flag": "-y",
      "next": "plan"
    },
    "plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "description": "Create execution plan with task decomposition",
      "args": "{phase}",
      "auto_flag": "--auto",
      "next": "execute"
    },
    "execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "description": "Run wave-based parallel task execution",
      "args": "{phase}",
      "next": "done"
    },
    "done": {
      "type": "terminal",
      "status": "success",
      "summary": "UI craft build pipeline completed successfully"
    }
  }
}
