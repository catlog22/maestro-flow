{
  "$schema": "./chain-graph.schema.json",
  "id": "roadmap-driven",
  "name": "Roadmap-Driven",
  "description": "Init -> Roadmap -> Plan -> Execute pipeline",
  "version": "1.0.0",
  "tags": ["lifecycle", "roadmap"],
  "entry": "init",
  "inputs": {
    "phase": { "type": "string" },
    "description": { "type": "string", "required": true }
  },
  "defaults": { "analyze": true },
  "nodes": {
    "init": {
      "type": "command",
      "cmd": "maestro-init",
      "description": "Initialize project structure and state files",
      "next": "roadmap"
    },
    "roadmap": {
      "type": "command",
      "cmd": "maestro-roadmap",
      "description": "Interactive roadmap creation with iterative refinement",
      "args": "\"{description}\"",
      "next": "plan"
    },
    "plan": {
      "type": "command",
      "cmd": "maestro-plan",
      "description": "Create execution plan with task decomposition",
      "args": "{phase}",
      "auto_flag": "--auto",
      "next": "execute"
    },
    "execute": {
      "type": "command",
      "cmd": "maestro-execute",
      "description": "Run wave-based parallel task execution",
      "args": "{phase}",
      "next": "done"
    },
    "done": {
      "type": "terminal",
      "status": "success",
      "summary": "Roadmap-driven pipeline completed successfully"
    }
  }
}
